.venv/
.cloudflared/
.cache/
__pycache__/
*.pyc
*.pyo
outputs/
last_load.json
settings.json
# Local A/B / verification harnesses — not part of the shipped product
scripts/
# Model files: ignore everything under models/ except the directory skeleton,
# so user weights/archives (.safetensors, .pth, .zip, .gguf, ...) never get
# committed by accident.
models/**
!models/**/
!models/**/.gitkeep
# Extensions: ignore user-installed extensions + runtime state, ship the example
# and this folder's README. The example-watermark/ folder is tracked so the
# reference extension ships with the repo.
extensions/*
!extensions/README.md
!extensions/example-watermark
*.egg-info/
dist/
build/
wandb/
